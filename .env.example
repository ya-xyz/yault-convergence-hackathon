# =============================================================================
# Yault Asset Management Platform — Environment Variables
# Copy this file to .env and fill in the values for your environment.
#
# Non-sensitive defaults come from env/*.json via `npm run env:dev`.
# This file holds SECRETS only — values here override env/.env.<profile>.
# =============================================================================

# --- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# --- Authentication -----------------------------------------------------------
# Required in production. Generate with: openssl rand -hex 32
JWT_SECRET=
# Client session HMAC secret (min 32 chars). Auto-generated if unset, but sessions won't survive restarts.
# Generate with: openssl rand -hex 32
CLIENT_SESSION_SECRET=

# --- drand Network (public beacon, no credentials needed) ---------------------
DRAND_CHAIN_HASH=dbd506d6ef76e5f386f41c651dcb808c5bcbd75471cc4eafa3f4df7ad4e4c493

# --- Arweave ------------------------------------------------------------------
ARWEAVE_GATEWAY=https://arweave.net
# Path to Arweave wallet JWK file (required for uploads)
ARWEAVE_WALLET_JWK=

# --- Email Notifications ------------------------------------------------------
# Provider: "console" (dev, prints to stdout), "sendgrid", "resend", or "mailgun"
EMAIL_PROVIDER=console
EMAIL_API_KEY=
EMAIL_FROM=noreply@yault.xyz
# Required when EMAIL_PROVIDER=mailgun (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=

# --- Trial Requests -----------------------------------------------------------
TRIAL_REQUEST_EMAIL=admin@example.com

# --- tlock Background Monitor -------------------------------------------------
ENABLE_TLOCK_MONITOR=false
TLOCK_POLL_INTERVAL_MS=60000

# --- Chain APIs ---------------------------------------------------------------
ETHERSCAN_API_KEY=

# --- Database (future: replace in-memory store) -------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/yault
# DATABASE_URL=sqlite:///path/to/yault.db

# --- Smart Contract Deployment (contracts/.env) -------------------------------
# DEPLOYER_PRIVATE_KEY=0x...
# PLATFORM_FEE_RECIPIENT=0x...

# --- Vault & Chain (app config — use mainnet values in production) -------------
# YaultVault (ERC-4626) address. When set, balance/deposit/redeem/harvest use on-chain.
# Sepolia deployment (fill from your deploy output):
VAULT_ADDRESS=0xCdF23BF390B1c4BEb811371466b04BB17759FB14
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VAULT_CHAIN_ID=11155111
VAULT_UNDERLYING_DECIMALS=6
# For mainnet: VAULT_ADDRESS=0x... EVM_RPC_URL=https://eth.llamarpc.com VAULT_CHAIN_ID=1

# --- Trigger cooldown (release decision wait before finalization) ------------
# Cooldown in minutes (e.g. 10 for demo). If unset, uses COOLDOWN_DEFAULT_HOURS (default 168 = 7 days).
# COOLDOWN_DEFAULT_MINUTES=10

# --- ReleaseAttestation / Oracle (chain attestation + fallback) --------------
# Set ORACLE_ATTESTATION_ENABLED=true to use chain attestation; then set:
# RELEASE_ATTESTATION_ADDRESS=   # ReleaseAttestation contract address
# RELEASE_ATTESTATION_RELAYER_PRIVATE_KEY=  # relayer wallet (must be setFallbackSubmitter(relayer, true) on contract)
# ORACLE_RPC_URL=                # optional, defaults to EVM_RPC_URL / Sepolia in dev
# ORACLE_INTERNAL_API_KEY=       # optional; in production set for POST /api/trigger/from-oracle (cron/CRE only)
# ORACLE_ATTESTATION_ENABLED=

# --- Path Claim (YaultPathClaim — deposit / registerPath / claim) ------------
# PATH_CLAIM_ADDRESS=            # YaultPathClaim contract address
# PATH_CLAIM_ASSET_ADDRESS=      # e.g. USDC on same chain (Sepolia: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238)
# PATH_CLAIM_CHAIN_ID=           # optional, defaults to VAULT_CHAIN_ID
# PATH_CLAIM_RPC_URL=            # optional, defaults to EVM_RPC_URL

# --- Platform Ops (admin dashboard) -------------------------------------------
# Comma-separated EVM addresses allowed to log in to the Ops portal.
# Uncomment the next line to use the test wallet (Client + Authority + Ops):
ADMIN_WALLETS=0x00e1304043f99B88F89e7f7a742dc0D66a1de17a

# --- E2E Tests ----------------------------------------------------------------
# RUN_TESTNET_TESTS=true
# RUN_SLOW_TESTS=true
